	</string>
	<string id="ui_mcm_itts_stat_clock_blink">
		<text>Blinking separators</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_blink_desc">
		<text>Softly pulse the ':' separators of the real-life clock once per second. Subtle: they dim, never disappear.</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_font">
		<text>Clock font</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_font_desc">
