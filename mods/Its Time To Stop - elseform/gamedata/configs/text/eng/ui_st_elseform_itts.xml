	</string>
	<string id="ui_mcm_itts_stat_show_total">
		<text>Show total playtime stat in PDA</text>
	</string>
	<string id="ui_mcm_itts_stat_show_total_desc">
		<text>Show the Time Played row in the PDA statistics strip. Applied on game restart.</text>
	</string>
	<string id="ui_mcm_itts_stat_show_session">
		<text>Show session playtime stat in PDA</text>
	</string>
	<string id="ui_mcm_itts_stat_show_session_desc">
		<text>Show the Session row in the PDA statistics strip. Applied on game restart.</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_enabled">
		<text>Display real-time HUD clock</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_enabled_desc">
		<text>Show the real local-time clock on the HUD.</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_pos">
		<text>Clock position</text>
	</string>
	<string id="ui_mcm_itts_stat_clock_pos_desc">
		<text>Compass presets follow the active minimap and mirror its stock clock anchor. The below-right presets either move the stock in-game clock to below-left or replace it entirely. Restart required.</text>
	</string>
	<string id="ui_mcm_lst_itts_clock_pos_compass_al">
		<text>Compass: above-left</text>
	</string>
	<string id="ui_mcm_lst_itts_clock_pos_compass_ar">
